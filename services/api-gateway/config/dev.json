{
  "environment": "dev",
  "services": {
    "users": {
      "name": "user-service",
      "base_url": "http://user-service:8082",
      "api_version": "v1",
      "timeout": "30s",
      "retries": 3,
      "service_endpoint": "/api/v1/users",
      "health_endpoint": "/api/v1/health",
      "metrics_endpoint": "/api/v1/metrics"
    },
    "orders": {
      "name": "order-service", 
      "base_url": "http://order-service:8083",
      "api_version": "v1",
      "timeout": "30s",
      "retries": 3,
      "service_endpoint": "/api/v1/orders",
      "health_endpoint": "/api/v1/health",
      "metrics_endpoint": "/api/v1/metrics"
    }
  },
  "rate_limits": {
    "requests_per_minute": 1000,
    "window_size": "1m"
  },
  "gateway": {
    "port": 8081,
    "read_timeout": "30s",
    "write_timeout": "30s"
  }
}